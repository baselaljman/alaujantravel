rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // 0. Default Deny
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------
    // 1. Global Helper Functions
    // -----------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isVerified() {
      return isSignedIn() && (
        ('email_verified' in request.auth.token && request.auth.token.email_verified == true) || 
        ('firebase' in request.auth.token && 'sign_in_provider' in request.auth.token.firebase && request.auth.token.firebase.sign_in_provider == 'phone') ||
        (hasUserDoc() && (
          getUserDoc().get('role', 'user') in ['admin', 'driver', 'staff']
        ))
      );
    }

    // Custom helper to get string email or empty string safely
    function userEmail() {
      return (isSignedIn() && 'email' in request.auth.token) ? request.auth.token.email : '';
    }

    // Custom helper to get string phone or empty string safely
    function userPhone() {
      return (isSignedIn() && 'phone_number' in request.auth.token) ? request.auth.token.phone_number : '';
    }

    function isAdmin() {
      return isSignedIn() && (
        (userEmail().lower() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com", "a0537136212@icloud.com", "maan500069261@gmail.com"]) ||
        (hasUserDoc() && getUserDoc().get('role', 'user') == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && (
        (role == 'admin' && isAdmin()) ||
        (hasUserDoc() && getUserDoc().get('role', 'user') == role)
      );
    }

    function hasPermission(p) {
      return isSignedIn() && (
        isAdmin() || 
        (hasUserDoc() && (
          getUserDoc().get('role', 'user') == 'staff' && 
          p in getUserDoc().get('permissions', [])
        ))
      );
    }

    // Safe getters for resource data
    function incoming() {
      return request.resource.data;
    }

    // Safe getters for existing resource data
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // --- Entity Validations ---

    function isValidTrip(data) {
      return data.get('from', '') is string && data.get('from', '').size() <= 100 &&
             data.get('to', '') is string && data.get('to', '').size() <= 100 &&
             data.get('date', '') is string && data.get('date', '').size() <= 20 &&
             data.get('status', 'scheduled') in ['scheduled', 'active', 'paused', 'completed', 'cancelled'];
    }

    function isValidBooking(data) {
      return data.get('tripId', '') is string && isValidId(data.get('tripId', '')) &&
             data.get('passengerName', '') is string && data.get('passengerName', '').size() <= 128 &&
             data.get('passengerPhone', '') is string && data.get('passengerPhone', '').size() <= 20 &&
             (data.get('seatNumber', 0) is int || data.get('seatNumber', 0) is float) && data.get('seatNumber', 0) >= 1 && data.get('seatNumber', 0) <= 100;
    }

    // Safe validation of parcels
    function isValidParcel(data) {
      return data.get('senderName', '') is string && data.get('senderName', '').size() <= 128 &&
             data.get('receiverName', '') is string && data.get('receiverName', '').size() <= 128 &&
             data.get('tripId', '') is string && isValidId(data.get('tripId', '')) &&
             data.get('status', 'pending') in ['pending', 'shipped', 'delivered'];
    }

    // -----------------------------------------------------------------
    // 2. Collection Rules
    // -----------------------------------------------------------------

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || hasPermission('view_users') || hasPermission('manage_users');
      allow list: if isSignedIn();

      allow create: if isOwner(userId) && (
        incoming().get('role', 'user') in ['user', 'driver', 'staff'] ||
        (incoming().get('role', 'user') == 'admin' && userEmail().lower() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com", "a0537136212@icloud.com", "maan500069261@gmail.com"])
      );
      allow create: if isAdmin() || hasPermission('manage_users');
      
      allow update: if isOwner(userId) && (
        // Users can't change their own role or permissions unless they are in the allowed admin list
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'fcmToken', 'deviceType', 'photoURL']) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'phoneNumber', 'fcmToken', 'deviceType', 'photoURL']) &&
         incoming().get('role', 'user') == 'admin' &&
         userEmail().lower() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com", "a0537136212@icloud.com", "maan500069261@gmail.com"])
      );
      allow update: if isAdmin() || hasPermission('manage_users');
      allow delete: if isAdmin() || hasPermission('manage_users') || isOwner(userId) || (
        isSignedIn() && (
          existing().get('email', '') == userEmail() ||
          existing().get('email', '').lower() == userEmail().lower()
        )
      );
    }

    // --- Trips ---
    match /trips/{tripId} {
      allow read: if true;
      allow create: if isAdmin() || hasPermission('manage_trips');
      allow update: if (
        // Case 1: Booking update (only seats)
        (incoming().diff(existing()).affectedKeys().hasOnly(['availableSeats', 'bookedSeats'])) ||
        // Case 2: Driver updating status of their trip
        (hasRole('driver') && existing().get('driverId', '') == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Case 3: Staff updating driverId
        (hasPermission('manage_trips') && incoming().diff(existing()).affectedKeys().hasOnly(['driverId'])) ||
        // Case 4: Admin/Staff full update
        isAdmin() || 
        hasPermission('manage_trips')
      ) && isValidTrip(incoming()) && isValidId(tripId);
      allow delete: if (isAdmin() || hasPermission('manage_trips')) && isValidId(tripId);
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (
        resource.data.get('userId', '') == request.auth.uid ||
        resource.data.get('passengerEmail', '') == userEmail() ||
        resource.data.get('passengerEmail', '').lower() == userEmail().lower() ||
        resource.data.get('passengerPhone', '') == userPhone() ||
        isAdmin() || 
        hasPermission('view_bookings') || 
        hasPermission('manage_bookings') ||
        hasRole('staff') ||
        hasRole('driver') ||
        // Driver of the trip can see bookings
        (exists(/databases/$(database)/documents/trips/$(resource.data.get('tripId', ''))) && 
         get(/databases/$(database)/documents/trips/$(resource.data.get('tripId', ''))).data.get('driverId', '') == request.auth.uid)
      );
      
      allow list: if isSignedIn();
      
      allow create: if (
                      isValidBooking(incoming()) && 
                      exists(/databases/$(database)/documents/trips/$(incoming().get('tripId', ''))) &&
                      (incoming().get('userId', '') == 'guest' || (isSignedIn() && incoming().get('userId', '') == request.auth.uid))
                    ) || isAdmin() || hasPermission('manage_bookings');
      
      allow update: if (
        (isSignedIn() && existing().get('userId', '') == request.auth.uid) || 
        isAdmin() || 
        hasPermission('manage_bookings')
      ) && isValidBooking(incoming());
      
      allow delete: if isAdmin() || hasPermission('manage_bookings') || (isSignedIn() && existing().get('userId', '') == request.auth.uid);
    }

    // --- Parcels ---
    match /parcels/{parcelId} { 
      allow read: if true; 
      allow create: if isAdmin() || hasPermission('manage_parcels');
      allow update: if (
        isAdmin() || 
        hasPermission('manage_parcels') ||
        // Driver of the trip can update parcel status
        (hasRole('driver') && 
         exists(/databases/$(database)/documents/trips/$(existing().get('tripId', ''))) && 
         get(/databases/$(database)/documents/trips/$(existing().get('tripId', ''))).data.get('driverId', '') == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      ) && isValidParcel(incoming()) && isValidId(parcelId);
      allow delete: if (isAdmin() || hasPermission('manage_parcels')) && isValidId(parcelId);
    }

    // --- Cities & Countries ---
    match /cities/{id} { allow read: if true; allow write: if isAdmin() || hasPermission('manage_cities') || hasPermission('manage_trips'); }
    match /countries/{id} { allow read: if true; allow write: if isAdmin() || hasPermission('manage_cities') || hasPermission('manage_trips'); }
    
    // --- Buses ---
    match /buses/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || hasPermission('manage_buses') || hasPermission('manage_trips'); 
    }

    // --- Banners ---
    match /banners/{id} { 
      allow read: if true; 
      allow write: if isAdmin() || hasPermission('manage_banners'); 
    }
    
    // --- Locations (Live Tracking) ---
    match /locations/{tripId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/trips/$(tripId)) && 
        get(/databases/$(database)/documents/trips/$(tripId)).data.get('driverId', '') == request.auth.uid
      );
    }

    // --- Notifications ---
    match /notifications/{id} { 
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasRole('staff');
    }
    
    // --- Metadata ---
    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('manage_trips') || hasPermission('manage_parcels');
    }

    // --- Settings ---
    match /settings/{id} {
      allow read: if true;
      allow write: if isSignedIn() && (
        isAdmin() || 
        hasRole('admin') ||
        hasRole('staff') ||
        (userEmail().lower() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com", "a0537136212@icloud.com", "maan500069261@gmail.com"]) ||
        (hasUserDoc() && getUserDoc().get('role', 'user') in ['admin', 'staff'])
      );
    }

    // --- Devices (Push Notifications) ---
    match /devices/{deviceId} {
      allow read, create, update: if true;
      allow delete: if isAdmin() || (isSignedIn() && existing().get('userId', '') == request.auth.uid);
    }

    // --- SMS OTPs ---
    match /sms_otps/{id} {
      allow read, write: if false;
    }

    // --- Delete Requests (GDPR / Google Play Compliance) ---
    match /delete_requests/{id} {
      allow create: if true;
      allow read, write: if isAdmin() || hasPermission('manage_users');
    }
  }
}
