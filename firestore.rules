rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // 0. Default Deny
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -----------------------------------------------------------------
    // 1. Global Helper Functions
    // -----------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'phone' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'driver', 'staff']
        ))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && isValidId(userId) && request.auth.uid == userId;
    }

    function userEmail() {
      return isSignedIn() && 'email' in request.auth.token ? request.auth.token.email : null;
    }

    function userPhone() {
      return isSignedIn() && 'phone_number' in request.auth.token ? request.auth.token.phone_number : null;
    }

    function isAdmin() {
      return isVerified() && (
        (userEmail() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com"]) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasRole(role) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role)
      );
    }

    function hasPermission(p) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', []).hasAny([p]))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidTrip(data) {
      return data.from is string && data.from.size() <= 100 &&
             data.to is string && data.to.size() <= 100 &&
             data.date is string && data.date.size() <= 20 &&
             data.status in ['scheduled', 'active', 'paused', 'completed', 'cancelled'];
    }

    function isValidBooking(data) {
      return data.tripId is string && isValidId(data.tripId) &&
             data.passengerName is string && data.passengerName.size() <= 128 &&
             data.passengerPhone is string && data.passengerPhone.size() <= 20 &&
             (data.seatNumber is int || data.seatNumber is float) && data.seatNumber >= 1 && data.seatNumber <= 100;
    }

    function isValidParcel(data) {
      return data.senderName is string && data.senderName.size() <= 128 &&
             data.receiverName is string && data.receiverName.size() <= 128 &&
             data.tripId is string && isValidId(data.tripId) &&
             data.status in ['pending', 'shipped', 'delivered'];
    }

    // -----------------------------------------------------------------
    // 2. Collection Rules
    // -----------------------------------------------------------------

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || hasPermission('view_users');
      allow list: if isAdmin() || hasPermission('view_users') || (isSignedIn() && (resource.data.email == userEmail() || resource.data.uid == request.auth.uid));

      allow create: if isOwner(userId) && (
        incoming().role == 'user' ||
        (incoming().role == 'admin' && userEmail() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com"])
      );
      allow create: if isAdmin();
      
      allow update: if isOwner(userId) && (
        // Users can't change their own role or permissions unless they are in the allowed admin list
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber', 'fcmToken', 'deviceType', 'photoURL']) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'phoneNumber', 'fcmToken', 'deviceType', 'photoURL']) &&
         incoming().role == 'admin' &&
         userEmail() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com"])
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Trips ---
    match /trips/{tripId} {
      allow read: if true;
      allow create: if isAdmin() || hasPermission('manage_trips');
      allow update: if (
        // Case 1: Booking update (only seats)
        (incoming().diff(existing()).affectedKeys().hasOnly(['availableSeats', 'bookedSeats'])) ||
        // Case 2: Driver updating status of their trip
        (hasRole('driver') && existing().driverId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Case 3: Staff updating driverId
        (hasPermission('manage_trips') && incoming().diff(existing()).affectedKeys().hasOnly(['driverId'])) ||
        // Case 4: Admin/Staff full update
        isAdmin() || 
        hasPermission('manage_trips')
      ) && isValidTrip(incoming()) && isValidId(tripId);
      allow delete: if isAdmin() && isValidId(tripId);
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        (resource.data.userId == request.auth.uid) ||
        (userEmail() != null && resource.data.get('passengerEmail', '') == userEmail()) ||
        (userPhone() != null && resource.data.get('passengerPhone', '') == userPhone()) ||
        isAdmin() || 
        hasPermission('view_bookings') || 
        hasPermission('staff') ||
        hasRole('driver') ||
        // Driver of the trip can see bookings
        (exists(/databases/$(database)/documents/trips/$(resource.data.tripId)) && 
         get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.driverId == request.auth.uid)
      );
      
      allow create: if isValidBooking(incoming()) && 
                    exists(/databases/$(database)/documents/trips/$(incoming().tripId)) &&
                    (incoming().userId == 'guest' || (isSignedIn() && incoming().userId == request.auth.uid));
      
      allow update: if (
        (isOwner(existing().userId)) || 
        isAdmin() || 
        hasPermission('manage_bookings')
      ) && isValidBooking(incoming());
      
      allow delete: if isAdmin();
    }

    // --- Parcels ---
    match /parcels/{parcelId} { 
      allow read: if true; 
      allow create: if isAdmin() || hasPermission('manage_parcels');
      allow update: if (
        isAdmin() || 
        hasPermission('manage_parcels') ||
        // Driver of the trip can update parcel status
        (hasRole('driver') && 
         exists(/databases/$(database)/documents/trips/$(existing().tripId)) && 
         get(/databases/$(database)/documents/trips/$(existing().tripId)).data.driverId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      ) && isValidParcel(incoming()) && isValidId(parcelId);
      allow delete: if isAdmin() && isValidId(parcelId);
    }

    // --- Cities & Countries ---
    match /cities/{id} { allow read: if true; allow write: if isAdmin() || hasPermission('manage_trips'); }
    match /countries/{id} { allow read: if true; allow write: if isAdmin() || hasPermission('manage_trips'); }
    
    // --- Buses ---
    match /buses/{id} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin() || hasPermission('manage_trips'); 
    }

    // --- Banners ---
    match /banners/{id} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
    // --- Locations (Live Tracking) ---
    match /locations/{tripId} {
      allow read: if true;
      allow write: if isAdmin() || (
        isVerified() && 
        exists(/databases/$(database)/documents/trips/$(tripId)) && 
        get(/databases/$(database)/documents/trips/$(tripId)).data.driverId == request.auth.uid
      );
    }

    // --- Notifications ---
    match /notifications/{id} { 
      allow read: if isSignedIn() && (
        isAdmin() || 
        hasPermission('staff') ||
        resource.data.get('targetId', '') == request.auth.uid || 
        resource.data.get('type', '') == 'all' ||
        resource.data.get('type', '') == 'users' ||
        resource.data.get('type', '') == 'drivers'
      );
      allow write: if isAdmin();
    }
    
    // --- Metadata ---
    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Devices (Push Notifications) ---
    match /devices/{deviceId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // --- SMS OTPs ---
    match /sms_otps/{id} {
      allow read, write: if false;
    }
  }
}
