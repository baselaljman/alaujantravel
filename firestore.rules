rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // 1. Global Helper Functions
    // -----------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userEmail() {
      return isSignedIn() && 'email' in request.auth.token ? request.auth.token.email : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        userEmail() in ["baselaljman@gmail.com", "maan500094210@gmail.com", "maan1@gmail.com"] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasPermission(p) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', []).hasAny([p]))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -----------------------------------------------------------------
    // 2. Collection Rules
    // -----------------------------------------------------------------

    // --- Users ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || hasPermission('view_users');
      allow list: if isAdmin() || hasPermission('view_users') || 
                  (isSignedIn() && userEmail() != null && resource.data.email == userEmail());

      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Trips ---
    match /trips/{tripId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('manage_trips');
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        hasPermission('view_bookings') || 
        hasPermission('driver') ||
        hasPermission('staff') ||
        (resource.data.userId == request.auth.uid) ||
        (userEmail() != null && resource.data.get('passengerEmail', '') == userEmail()) ||
        ('phone_number' in request.auth.token && resource.data.get('passengerPhone', '') == request.auth.token.phone_number)
      );
      
      allow create: if isSignedIn();
      allow update: if isOwner(existing().userId) || isAdmin() || hasPermission('manage_bookings');
      allow delete: if isAdmin();
    }

    // --- Cities, Countries, buses, banners ---
    match /cities/{id} { allow read: if true; allow write: if isAdmin() || hasPermission('manage_trips'); }
    match /countries/{id} { allow read: if true; allow write: if isAdmin() || hasPermission('manage_trips'); }
    match /buses/{id} { allow read: if isSignedIn(); allow write: if isAdmin() || hasPermission('manage_trips'); }
    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    
    // --- Parcels ---
    match /parcels/{id} { 
      allow read: if true; 
      allow write: if isAdmin() || hasPermission('manage_parcels');
    }

    // --- Locations (Live Tracking) ---
    match /locations/{tripId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('driver');
    }

    // --- Notifications ---
    match /notifications/{id} { 
      allow read: if isSignedIn() && (isAdmin() || resource.data.targetId == request.auth.uid || resource.data.type == 'all');
      allow write: if isAdmin();
    }
    
    // --- Metadata & Settings ---
    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // -----------------------------------------------------------------
    // 3. Catch-all: Deny everything by default
    // -----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
